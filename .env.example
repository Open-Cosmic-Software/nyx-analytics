# ── Nyx Analytics configuration — copy to .env and fill in ──
# Port (bound to 127.0.0.1; put a reverse proxy / TLS in front)
PORT=3920

# Dashboard passphrase (plaintext; keep .env at chmod 600)
WEB_PASSWORD=change-me-to-a-strong-passphrase

# Secret for signing session tokens — long random string
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SESSION_SECRET=change-me

# Salt for the daily one-way visitor hash (rotate to reset all visitor identities)
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
INGEST_SALT=change-me

# SQLite database path
DB_PATH=./data/analytics.db

# API key for agents / CLI (Bearer token) — generate a long random string
API_KEY=change-me

# Data minimisation: auto-purge raw events older than N days (0 = keep forever)
DATA_RETENTION_DAYS=0
